{
  "$id": "task.schema.json",
  "title": "Claude Code Task",
  "type": "object",
  "required": ["id", "subject", "status"],
  "properties": {
    "id": { "type": "string" },
    "subject": { "type": "string" },
    "description": { "type": ["string", "null"] },
    "activeForm": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed"]
    },
    "blocks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockedBy": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "_internal": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
